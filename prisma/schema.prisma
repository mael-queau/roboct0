// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  TWITCH
  DISCORD
}

model BotToken {
  platform    Platform @id
  accessToken String
  expiresAt   DateTime
}

model State {
  id Int @id @default(autoincrement())

  value       String
  createdAt   DateTime            @default(now())
  pendingLink PendingAccountLink?

  @@unique([value])
}

model Channel {
  id Int @id @default(autoincrement())

  channelId          String
  username           String
  token              String
  refreshToken       String
  lastRefresh        DateTime             @default(now())
  registeredAt       DateTime             @default(now())
  expiresAt          DateTime
  enabled            Boolean              @default(true)
  quoteIndex         Int                  @default(0)
  guilds             Guild[]
  quotes             Quote[]
  commands           Command[]
  users              User[]
  ChannelLoveCounter ChannelLoveCounter[]

  @@unique([channelId])
}

model User {
  id Int @id @default(autoincrement())

  twitchId                 String
  discordId                String?              @unique
  registeredAt             DateTime             @default(now())
  linkedAt                 DateTime?
  optOut                   Boolean              @default(false)
  channels                 Channel[]
  channelCounters          ChannelLoveCounter[]
  miscellaneousLoveCounter Int                  @default(1)

  @@unique([twitchId])
}

model ChannelLoveCounter {
  id Int @id @default(autoincrement())

  user      User    @relation(fields: [userId], references: [twitchId], onDelete: Cascade)
  userId    String  @unique
  channel   Channel @relation(fields: [channelId], references: [channelId], onDelete: Cascade)
  channelId String  @unique
  counter   Int     @default(0)

  @@unique([userId, channelId])
}

model PendingAccountLink {
  id Int @id @default(autoincrement())

  discordId String
  state     State  @relation(fields: [stateId], references: [id], onDelete: Cascade)
  stateId   Int    @unique
}

model Quote {
  id Int @id @default(autoincrement())

  quoteId   Int
  content   String
  date      DateTime @default(now())
  enabled   Boolean  @default(true)
  channel   Channel  @relation(fields: [channelId], references: [channelId], onDelete: Cascade)
  channelId String

  @@unique([channelId, quoteId])
}

model Command {
  id Int @id @default(autoincrement())

  keyword   String
  content   String
  enabled   Boolean    @default(true)
  channel   Channel    @relation(fields: [channelId], references: [channelId], onDelete: Cascade)
  channelId String
  variables Variable[]

  @@unique([channelId, keyword])
}

model Variable {
  id Int @id @default(autoincrement())

  name      String
  value     Int     @default(0)
  command   Command @relation(fields: [commandId], references: [id], onDelete: Cascade)
  commandId Int

  @@unique([commandId, name])
}

model Guild {
  id Int @id @default(autoincrement())

  guildId         String
  token           String
  refreshToken    String
  lastRefresh     DateTime         @default(now())
  registeredAt    DateTime         @default(now())
  expiresAt       DateTime
  enabled         Boolean          @default(true)
  channels        Channel[]
  modRoles        ModRole[]
  botTextChannels BotTextChannel[]

  @@unique([guildId])
}

model ModRole {
  id Int @id @default(autoincrement())

  guild   Guild  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  guildId String
  roleId  String

  @@unique([guildId, roleId])
}

model BotTextChannel {
  id Int @id @default(autoincrement())

  guild         Guild  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  guildId       String
  textChannelId String

  @@unique([guildId, textChannelId])
}
